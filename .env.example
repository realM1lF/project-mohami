# API Keys - Diese müssen mit echten Werten gefüllt werden
# Siehe Dokumentation für Setup-Anleitung

# GitHub Personal Access Token
# Benötigte Rechte: repo, workflow
# Erstellen unter: https://github.com/settings/tokens
GITHUB_TOKEN=ghp_YOUR_GITHUB_TOKEN_HERE

# Repository für Tests (format: owner/repo)
TEST_REPO=username/repository-name

# Kimi API Key (via OpenRouter oder direkt)
# OpenRouter: https://openrouter.ai/keys
KIMI_API_KEY=sk-or-v1-YOUR_OPENROUTER_KEY_HERE

# Alternative: Direkter Kimi Key (falls verfügbar)
# KIMI_API_KEY=sk-kimi-YOUR_KIMI_KEY_HERE

# OpenRouter API Key (falls Kimi über OpenRouter läuft)
OPEN_ROUTER_API_KEY=sk-or-v1-YOUR_OPENROUTER_KEY_HERE

# Agent Configuration
USE_INTELLIGENT_AGENT=true

# Optional: Redis URL (default: redis://localhost:6379)
# REDIS_URL=redis://localhost:6379

# Optional: ChromaDB Pfad (default: ./data/chroma)
# CHROMA_PERSIST_DIR=./data/chroma

# Optional: Datenbank URL (default: sqlite:///./kanban.db)
# DATABASE_URL=sqlite:///./kanban.db
